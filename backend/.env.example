# ── Mata AI — ejemplo de variables de entorno ───────────────────────────────
# Copia las que necesites a tu archivo .env (NO subas el .env real a git).

# --- PayPal (cobros: suscripciones + paquetes de créditos) ------------------
# 1) Crea una app en https://developer.paypal.com/dashboard/applications
#    y copia el Client ID y el Secret aquí.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# "sandbox" para probar sin dinero real; "live" para cobrar de verdad.
PAYPAL_ENV=sandbox
# 2) Ejecuta una vez:  cd backend && python -m scripts.paypal_setup
#    Pega aquí los dos IDs de plan que imprime.
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_BUSINESS=
# 3) (Opcional pero recomendado) ID del webhook que crees en el dashboard de PayPal,
#    apuntando a  https://TU-BACKEND/billing/paypal/webhook
PAYPAL_WEBHOOK_ID=

# URL pública del frontend (a donde PayPal regresa tras pagar).
# En producción ponla a tu dominio real, ej: https://mata-ai.web.app
PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (alternativa a PayPal; opcional) --------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Proveedores de IA (opcionales; sin ellos se usan los gratuitos/mock) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
KIE_API_KEY=

# --- Seguridad ---------------------------------------------------------------
# CÁMBIALOS en producción.
JWT_SECRET=change-me-in-production
SEED_ADMIN_EMAIL=admin@mata.ai
SEED_ADMIN_PASSWORD=cambia-esta-contrasena
