# ---- Core ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Database / cache (docker-compose service names) ----
DATABASE_URL=postgresql+asyncpg://mata:mata@db:5432/mata
REDIS_URL=redis://redis:6379/0

# ---- Auth (CHANGE jwt_secret in production!) ----
JWT_SECRET=please-change-this-to-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ---- Seed admin ----
SEED_ADMIN_EMAIL=admin@mata.ai
SEED_ADMIN_PASSWORD=admin12345

# ---- Provider keys (leave blank to use built-in mock providers) ----
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
# Premium voice (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# kie.ai — backup for images / AI video animation / Suno music (Viral AI Studio)
KIE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Models ----
CHAT_MODEL=claude-opus-4-8
CODE_MODEL=claude-opus-4-8
AGENT_MODEL=claude-opus-4-8

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
