# Plantilla de variables para producción en la VM (Oracle Cloud).
# Copia a ".env" en la VM y rellena los valores. NO subas el .env real a git.

# --- Dominio (para HTTPS de Caddy) ---
DOMAIN=mata-ai.duckdns.org

# --- Base de datos / seguridad ---
POSTGRES_PASSWORD=cambia-esto-por-algo-largo
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
ACCESS_TOKEN_TTL_MINUTES=120

# --- Admin inicial (no uses los defaults del README) ---
SEED_ADMIN_EMAIL=admin@tudominio.com
SEED_ADMIN_PASSWORD=cambia-esta-contraseña

# --- LLM (NVIDIA es el motor principal) ---
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Clips: transcripción de audio (Groq Whisper, gratis) ---
GROQ_API_KEY=
WHISPER_MODEL=whisper-large-v3

# --- Imágenes / video / música (opcional) ---
KIE_API_KEY=

# --- PayPal (cuando pases a cobrar) ---
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_BUSINESS=
PAYPAL_WEBHOOK_ID=

# --- CORS: el dominio del frontend en Firebase + tu dominio del backend ---
CORS_ORIGINS=https://mata-ai-236ad.web.app,https://mata-ai.duckdns.org

# URL pública del frontend (para redirects de PayPal)
PUBLIC_APP_URL=https://mata-ai-236ad.web.app
